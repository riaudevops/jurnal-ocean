---
import { ChevronRight } from "@lucide/astro";

export interface SubSubItem {
  name: string;
  href: string;
}

export interface SubItem {
  name: string;
  href: string;
  subSubItems?: SubSubItem[];
}

export interface MenuItem {
  name: string;
  href: string;
  subItems?: SubItem[];
}

const menuItems: MenuItem[] = [
  { name: "BERANDA", href: "/" },
  {
    name: "TENTANG KAMI",
    href: "/profil",
    subItems: [
      { name: "Profil Yayasan", href: "/profil" },
      { name: "Visi & Misi", href: "/profil#visi-misi" },
      { name: "Struktur Organisasi", href: "/profil#struktur-organisasi" },
    ],
  },
  {
    name: "PROGRAM",
    href: "/program",
    subItems: [
      { name: "Program Sosial", href: "/program#sosial" },
      { name: "Program Kemanusiaan", href: "/program#kemanusiaan" },
      { name: "Program Keagamaan", href: "/program#keagamaan" },
    ],
  },
  {
    name: "BERITA",
    href: "/berita",
  },
];
---

<div class="w-full fixed top-0 left-0 right-0 z-100 transition-all duration-500 ease-out" id="navbar-wrapper">
  <nav class="w-full bg-brand-primary text-brand-background shadow-lg relative z-100 transition-all duration-500 ease-out" id="navbar">
    <div class="w-full max-w-7xl mx-auto flex justify-between items-center px-6 2xl:px-8 py-4">
      <a href="/" class="flex items-baseline gap-3 cursor-pointer hover:opacity-90 transition-opacity duration-200 shrink-0">
        <span class="logo-mark">S</span>
        <span class="logo-name">Sawiyan</span>
        <span class="logo-sub">Yayasan</span>
      </a>

      <div class="hidden xl:flex items-center gap-8">
        <ul class="flex items-center gap-8 text-brand-background font-medium text-[0.85rem]">
          {
            menuItems.map((item) => (
              <li class={`relative group ${item.subItems && "cursor-pointer"}`}>
                <a href={item.href} class={`hover:text-brand-primary-lighter transition-colors duration-200 ${!item.subItems && "cursor-pointer"} nav-link`}>
                  {item.name}
                  {item.subItems && (
                    <svg class="inline w-4 h-4 ml-1 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  )}
                </a>
                {item.subItems && (
                  <div class="absolute top-full left-1/2 -translate-x-1/2 w-56 bg-brand-primary/95 backdrop-blur-sm text-brand-background shadow-xl rounded-lg mt-2 z-110 border border-white/10 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 ease-out transform translate-y-2 group-hover:translate-y-0">
                    <div class="py-2">
                      {item.subItems.map((subItem) => (
                        <div class="relative group/sub">
                          <a href={subItem.href} class="w-full flex justify-between items-center px-4 py-2 hover:bg-white/10 hover:text-brand-primary-lighter transition-all duration-200">
                            {subItem.name}
                            {subItem.subSubItems && <ChevronRight class="w-4 h-4 transition-transform duration-300 group-hover/sub:translate-x-1" />}
                          </a>

                          {subItem.subSubItems && (
                            <div class="absolute top-0 left-full w-56 bg-brand-primary/95 backdrop-blur-sm text-brand-background shadow-xl rounded-lg ml-2 z-120 border border-white/10 opacity-0 invisible group-hover/sub:opacity-100 group-hover/sub:visible transition-all duration-300 ease-out transform -translate-x-2 group-hover/sub:translate-x-0">
                              <div class="py-2">
                                {subItem.subSubItems.map((subSubItem) => (
                                  <a href={subSubItem.href} class="block px-4 py-2 hover:bg-white/10 hover:text-brand-primary-lighter transition-all duration-200 hover:pl-5">
                                    {subSubItem.href}
                                  </a>
                                ))}
                              </div>
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="xl:hidden flex gap-1 md:gap-2 justify-center items-center">
        <button id="hamburger-button" class="text-brand-background focus:outline-none transition-transform duration-300 active:scale-90">
          <svg id="hamburger-icon" class="md:w-8 md:h-8 w-6 h-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div id="mobile-menu" class="fixed top-0 left-0 w-full h-full bg-brand-primary z-100 transform -translate-y-full transition-transform duration-500 ease-in-out xl:hidden overflow-y-auto">
    <div class="mt-17.5">
      <div class="flex flex-col text-brand-background text-md font-semibold">
        {
          menuItems.map((item) => (
            <div class="border-b border-white/10 px-7 py-4 transition-colors duration-200 hover:bg-white/5">
              {!item.subItems ? (
                <a href={item.href} class="block w-full hover:text-brand-primary-lighter transition-colors duration-200">
                  {item.name}
                </a>
              ) : (
                <div>
                  <button class="accordion-toggle flex justify-between items-center w-full hover:text-brand-primary-lighter transition-colors duration-200">
                    <span>{item.name}</span>
                    <svg class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="accordion-panel max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
                    <div class="py-3.5 px-4 mt-4 flex flex-col gap-3 bg-white/5 rounded-lg">
                      {item.subItems.map((subItem) =>
                        !subItem.subSubItems ? (
                          <a href={subItem.href} class="block py-1 text-base font-medium text-brand-primary-lighter/80 hover:text-brand-background hover:pl-2 transition-all duration-200">
                            {subItem.name}
                          </a>
                        ) : (
                          <div>
                            <button class="accordion-toggle flex gap-3 items-center w-full py-1 text-base font-medium text-brand-primary-lighter/80 hover:text-brand-background transition-colors duration-200">
                              <span>{subItem.name}</span>
                              <svg class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                              </svg>
                            </button>
                            <div class="accordion-panel max-h-0 overflow-hidden transition-all duration-500 ease-in-out">
                              <div class="pl-4 py-2 mt-2 flex flex-col gap-2 bg-white/5 rounded-lg">
                                {subItem.subSubItems.map((subSubItem) => (
                                  <a href={subSubItem.href} class="block py-1 text-sm font-medium text-brand-primary-lighter/70 hover:text-brand-background hover:pl-2 transition-all duration-200">
                                    {subSubItem.name}
                                  </a>
                                ))}
                              </div>
                            </div>
                          </div>
                        ),
                      )}
                    </div>
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <style>
    .logo-mark {
      font-family: 'Fraunces', 'Times New Roman', serif;
      font-style: italic;
      font-weight: 400;
      font-size: 30px;
      line-height: 1;
      color: var(--color-primary-lighter);
    }

    .logo-name {
      font-family: 'Fraunces', 'Times New Roman', serif;
      font-weight: 600;
      font-size: 22px;
      letter-spacing: -0.01em;
    }

    .logo-sub {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--color-primary-lighter);
      padding-left: 12px;
      margin-left: 4px;
      border-left: 1px solid rgba(164, 178, 147, 0.4);
    }

    .nav-cta {
      display: inline-flex;
      align-items: center;
      background: var(--color-primary-lighter);
      color: var(--color-primary-darker);
      padding: 10px 20px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-decoration: none;
      border-radius: 100px;
      transition: background 0.2s, color 0.2s;
    }

    .nav-cta:hover {
      background: var(--color-background);
      color: var(--color-primary-darker);
    }

    .nav-link {
      position: relative;
      padding: 6px 0;
    }

    .nav-link::after {
      content: '';
      position: absolute;
      left: 50%;
      bottom: -2px;
      width: 0;
      height: 1.5px;
      background: var(--color-primary-lighter);
      transition: width 0.3s, left 0.3s;
    }

    .nav-link:hover::after {
      width: 100%;
      left: 0;
    }
  </style>

  <script>
    const hamburgerButton = document.getElementById("hamburger-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const hamburgerIcon = document.getElementById("hamburger-icon");

    hamburgerButton!.addEventListener("click", () => {
      const isMenuOpen = !mobileMenu!.classList.contains("-translate-y-full");

      if (isMenuOpen) {
        mobileMenu!.classList.add("-translate-y-full");
        hamburgerIcon!.classList.remove("rotate-90");
      } else {
        mobileMenu!.classList.remove("-translate-y-full");
        hamburgerIcon!.classList.add("rotate-90");
      }
    });

    const accordions = document.querySelectorAll(".accordion-toggle");
    accordions.forEach((accordion) => {
      accordion.addEventListener("click", () => {
        const panel = accordion.nextElementSibling as HTMLElement;
        const icon = accordion.querySelector("svg");

        if (panel.style.maxHeight && panel.style.maxHeight !== "0px") {
          panel.style.maxHeight = "0px";
          icon!.classList.remove("rotate-180");
        } else {
          panel.style.maxHeight = panel.scrollHeight + "px";
          icon!.classList.add("rotate-180");
        }
      });
    });
  </script>
</div>
